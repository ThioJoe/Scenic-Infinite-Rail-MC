# The inventory keeper: pins the rider's hotbar items and polices the rest
# of the inventory -- runs AS the player (main calls it for every adventure
# player each tick, so the items are always there and nothing else ever
# accumulates; stop takes them back):
#   hotbar.0  "Ride Settings"    book: sky mode, cart sound, hide cart, mobs aggro   (chest-minecart icon)
#   hotbar.1  "Visual Settings"  book: rain, time, torches, track light (page 2)     (soul-campfire icon)
#   hotbar.3  "Speed -"      .SPEEDSTEP blocks/s slower       (rail icon)
#   hotbar.4  "Speed Reset"  back to the default ride speed   (minecart icon)
#   hotbar.5  "Speed +"      .SPEEDSTEP blocks/s faster       (powered-rail icon)
#   hotbar.7  "Tips"      book: recommended game/video settings (plain book, no links)
#   hotbar.8  "Debug"     book: chat diagnostics + sidebar views                      (smithing-table icon)
# Layout: the settings books sit on the far left, the Debug book on the far
# right, the speed trio in between with empty slots (2 and 6) as visual
# separators -- Reset is the dead center of the hotbar (slot 4), flanked by
# decrease on its left and increase on its right.
#
# THE BOOK CLICKS GO THROUGH /trigger, NOT /function. Since 1.21.6, clicking
# a run_command link that needs elevated permissions (like /function) pops a
# confirmation screen on every single click -- even for operators. /trigger
# is runnable by every player at permission level 0, so each link just sets
# a number on the ir_menu trigger objective (created by load) and the
# menu_tick dispatcher turns it into the real call on the next tick. No
# confirmation screen, no operator requirement -- the menu works even for
# non-op players, matching Bedrock's native form. (The number map lives in
# menu_tick's header.)
#
# THE SPEED ITEMS are carrot_on_a_sticks -- the one item whose "used"
# statistic increments on any right-click (the ir_click objective; see
# speed_click) -- re-skinned via the minecraft:item_model component (a rail /
# a powered rail) and told apart by custom_data. One click = .SPEEDSTEP
# blocks/s (a fixed cross-edition constant from the shared consts.mcfunction).
# The books wear item_model disguises the same way (the item stays a
# written_book, so it still opens on use -- item_model is purely visual),
# plus enchantment_glint_override=false: a written_book renders with the
# enchanted shimmer by default, which read as four "glowing" hotbar icons.
#
# FORMAT NOTES (1.21.5+ text components, which the whole supported range
# 82-107 uses): pages are SNBT text components, click events are
# click_event:{action:"run_command",command:"..."} with NO leading slash,
# hover tips are hover_event:{action:"show_text",value:"..."}, and each
# page root is an empty {text:""} so its style can't bleed into the
# children via inheritance.
#
# RE-PIN ONLY WHAT IS MISSING OR WRONG. An unconditional per-tick clear +
# item replace re-fired the client's item-pickup animation every single
# tick, freezing all the icons on the animation's first (stretched) frame.
# Instead: count the occupied inventory slots -- more than the seven pinned
# ones means clutter (a pickup that slipped past the item sweep, a moved
# copy) and only THEN is the inventory wiped; each pinned slot is re-filled
# only while it doesn't hold its own item (matched by custom_data -- the
# books carry an ir_book marker for exactly this; BUMP its value whenever a
# book's pages change, or riders mid-ride keep the stale copy). At cruise
# the inventory is never touched at all.
execute store result score .inv ir if items entity @s container.* *
execute if score .inv ir matches 8.. run clear @s
# The offhand sits outside container.* -- F-swapping a pinned item there
# would dodge both the count and the slot checks, so empty it directly.
execute if items entity @s weapon.offhand * run item replace entity @s weapon.offhand with minecraft:air
# The Speed trio (all carrot_on_a_sticks, told apart by custom_data ir_spd
# -1/0/+1 -- see speed_click): Reset sits dead center at slot 4 between - and +.
execute unless items entity @s hotbar.3 minecraft:carrot_on_a_stick[minecraft:custom_data~{ir_spd:-1}] run item replace entity @s hotbar.3 with minecraft:carrot_on_a_stick[minecraft:item_model="minecraft:rail",minecraft:item_name="Speed -",minecraft:custom_data={ir_spd:-1},minecraft:lore=["Ride speed down"]] 1
execute unless items entity @s hotbar.4 minecraft:carrot_on_a_stick[minecraft:custom_data~{ir_spd:0}] run item replace entity @s hotbar.4 with minecraft:carrot_on_a_stick[minecraft:item_model="minecraft:minecart",minecraft:item_name="Speed Reset",minecraft:custom_data={ir_spd:0},minecraft:lore=["Reset ride speed to the default"]] 1
execute unless items entity @s hotbar.5 minecraft:carrot_on_a_stick[minecraft:custom_data~{ir_spd:1}] run item replace entity @s hotbar.5 with minecraft:carrot_on_a_stick[minecraft:item_model="minecraft:powered_rail",minecraft:item_name="Speed +",minecraft:custom_data={ir_spd:1},minecraft:lore=["Ride speed up"]] 1
execute unless items entity @s hotbar.0 minecraft:written_book[minecraft:custom_data~{ir_book:"ride-4"}] run item replace entity @s hotbar.0 with minecraft:written_book[minecraft:item_model="minecraft:chest_minecart",minecraft:enchantment_glint_override=false,minecraft:custom_data={ir_book:"ride-4"},written_book_content={title:"Ride Settings",author:"Scenic Rail",pages:[{text:"",extra:[{text:"Scenic Rail Mode\n",bold:true},{text:"ride settings\n\n",color:"gray"},{text:"Sky mode:  "},{text:"[On]",color:"dark_green",click_event:{action:"run_command",command:"trigger ir_menu set 7"},hover_event:{action:"show_text",value:"High-altitude cruise at a fixed height"}},{text:" "},{text:"[Off]",color:"dark_red",click_event:{action:"run_command",command:"trigger ir_menu set 8"},hover_event:{action:"show_text",value:"Glide back down to the terrain"}},{text:"\n\n"},{text:"Cart Sound:  "},{text:"[On]",color:"dark_green",click_event:{action:"run_command",command:"trigger ir_menu set 28"},hover_event:{action:"show_text",value:"The minecart sound while riding"}},{text:" "},{text:"[Off]",color:"dark_red",click_event:{action:"run_command",command:"trigger ir_menu set 29"},hover_event:{action:"show_text",value:"The silent glide"}},{text:"\n\n"},{text:"Cart:  "},{text:"[Hide]",color:"dark_green",click_event:{action:"run_command",command:"trigger ir_menu set 26"},hover_event:{action:"show_text",value:"Remove the visible minecart - ride on air with a clear view"}},{text:" "},{text:"[Show]",color:"dark_red",click_event:{action:"run_command",command:"trigger ir_menu set 27"},hover_event:{action:"show_text",value:"Bring the minecart back"}},{text:"\n\n"},{text:"Mobs aggro: "},{text:"[On]",color:"dark_green",click_event:{action:"run_command",command:"trigger ir_menu set 31"},hover_event:{action:"show_text",value:"Hostile mobs notice you and react - bow-draws, hisses, chases (default; you're untouchable regardless)"}},{text:" "},{text:"[Off]",color:"dark_red",click_event:{action:"run_command",c